{# =============================================================================
   Template: esi-lag.j2
   Renders EVPN ESI multi-homing Port-Channel configuration for a leaf.

   This template is called per-host from fabric-overlay.yml when
   esi_id is defined in host_vars.

   Required host_vars:
     esi_id             — EVPN ESI string  e.g. "0000:0000:0509:0000:0001"
     esi_lacp_id        — LACP system-ID   e.g. "0000.0509.0001"
     portchannels       — list of port-channel objects (see schema below)
                           (port_channels is also accepted for legacy host_vars)
     host_ports         — list of host-facing port objects

   portchannel schema:
     id:               integer           Port-Channel ID
     description:      string            Human-readable label
     mode:             active | passive   LACP mode
     members:          list[str]         Ethernet interfaces in the LAG
     vlan:             integer           Access VLAN (for access-mode PO)
     mtu:              integer           MTU on port-channel SVI
     esi:              string            ESI identifier (overrides host esi_id)
     lacp_system_id:   string            LACP system-ID (overrides host default)
     access_vlan:      integer           Legacy alias for vlan

   host_port schema:
     interface:        string            EOS interface name (e.g. Ethernet3)
     portchannel:      string            Port-Channel name (e.g. Port-Channel20)
     lacp_mode:        active | passive
     lacp_rate:        fast | normal
     mtu:              integer
     description:      string
   ============================================================================= #}

{% set esi_portchannels = portchannels | default(port_channels | default([])) %}
{% set host_port_channel_members = host_ports | default([]) | selectattr('portchannel', 'defined') | map(attribute='interface') | list %}

{% if esi_portchannels | length > 0 %}
! ── ESI Multi-homing: {{ inventory_hostname }}
! ── ESI ID: {{ esi_id }}
! ── LACP System-ID: {{ esi_lacp_id }}
!
{% for pc in esi_portchannels %}
{%   set pc_esi = pc.esi | default(esi_id) %}
{%   set esi_hex = pc_esi | replace(':', '') %}
{%   set esi_route_target = esi_hex[-12:-10] ~ ':' ~ esi_hex[-10:-8] ~ ':' ~ esi_hex[-8:-6] ~ ':' ~ esi_hex[-6:-4] ~ ':' ~ esi_hex[-4:-2] ~ ':' ~ esi_hex[-2:] %}
{%   set pc_access_vlan = pc.vlan | default(pc.access_vlan | default(1)) %}
{%   set pc_switchport_mode = 'trunk' if pc.mode | default('access') == 'trunk' else 'access' %}
{%   set pc_lacp_mode = pc.lacp_mode | default(pc.mode if pc.mode | default('active') in ['active', 'passive', 'on'] else 'active') %}
! Port-Channel{{ pc.id }} — {{ pc.description | default('ESI LAG') }}
interface Port-Channel{{ pc.id }}
   description {{ pc.description | default('ESI LAG — ' ~ inventory_hostname) }}
   !
{%   if pc_switchport_mode == 'trunk' %}
   switchport mode trunk
{%     if pc.trunk_vlans is defined %}
   switchport trunk allowed vlan {{ pc.trunk_vlans }}
{%     else %}
   switchport trunk allowed vlan {{ pc_access_vlan }}
{%     endif %}
{%   else %}
   switchport access vlan {{ pc_access_vlan }}
{%   endif %}
   !
   ! EVPN ESI multi-homing — RFC 7432
   evpn ethernet-segment
      identifier {{ pc_esi }}
      route-target import {{ esi_route_target }}
   !
   lacp system-id {{ pc.lacp_system_id | default(esi_lacp_id) }}
   spanning-tree portfast
   mtu {{ pc.mtu | default(mtu_host) }}
   no shutdown
!
{% endfor %}

! ── Member interfaces → Port-Channels
{% if host_ports is defined %}
{%   for port in host_ports %}
{%     if port.portchannel is defined %}
interface {{ port.interface }}
   description {{ port.description | default(port.interface ~ ' ESI LAG member') }}
   channel-group {{ port.portchannel | regex_replace('Port-Channel', '') }} mode {{ port.lacp_mode | default('active') }}
   mtu {{ port.mtu | default(mtu_host) }}
   no shutdown
!
{%     endif %}
{%   endfor %}
{% endif %}

{% for pc in esi_portchannels %}
{%   set pc_lacp_mode = pc.lacp_mode | default(pc.mode if pc.mode | default('active') in ['active', 'passive', 'on'] else 'active') %}
{%   for member in pc.members | default([]) %}
{%     if member not in host_port_channel_members %}
interface {{ member }}
   description {{ pc.description | default(member ~ ' ESI LAG member') }}
   channel-group {{ pc.id }} mode {{ pc_lacp_mode }}
   mtu {{ pc.mtu | default(mtu_host) }}
   no shutdown
!
{%     endif %}
{%   endfor %}
{% endfor %}

{% else %}
! No ESI Port-Channels defined for {{ inventory_hostname }}
{% endif %}
