/home                192.168.70.0/24(fsid=1,rw,sync,no_subtree_check,no_root_squash,insecure)
/home                192.168.50.0/24(fsid=1,rw,sync,no_subtree_check,no_root_squash,insecure)

# Export /shared - shared project directories (course teams, research groups)
/shared              192.168.70.0/24(fsid=2,rw,sync,no_subtree_check,no_root_squash,insecure)
