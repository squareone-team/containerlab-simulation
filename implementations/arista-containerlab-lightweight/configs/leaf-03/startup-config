! leaf-03 -- ASN 65003 | Services Zone
hostname leaf-03
!
service routing protocols model multi-agent
!
no aaa root
username admin privilege 15 role network-admin secret admin
!
management api http-commands
   protocol https
   no shutdown
!
vrf instance VRF-SERVICES
!
ip routing
ip routing vrf VRF-SERVICES
!
interface Loopback0
   description VTEP/Router-ID
   ip address 10.1.0.13/32
!
interface Ethernet1
   description P2P to spine-01
   no switchport
   ip address 10.0.0.5/31
   bfd interval 300 min-rx 300 multiplier 3
   no shutdown
!
interface Ethernet2
   description P2P to spine-02
   no switchport
   ip address 10.0.0.21/31
   bfd interval 300 min-rx 300 multiplier 3
   no shutdown
!
interface Ethernet3
   description server-svc-01
   switchport mode access
   switchport access vlan 50
   no shutdown
!
interface Ethernet4
   description server-svc-02
   switchport mode access
   switchport access vlan 60
   no shutdown
!
vlan 50
   name INTERNAL-WEB
!
vlan 60
   name LMS-PLATFORM
!
vlan 90
   name OOB-MGMT-OVERLAY
!
interface Vlan50
   description INTERNAL-WEB gateway
   vrf VRF-SERVICES
   ip address virtual 192.168.50.1/24
   no shutdown
!
interface Vlan60
   description LMS-PLATFORM gateway
   vrf VRF-SERVICES
   ip address virtual 192.168.60.1/24
   no shutdown
!
interface Vxlan1
   vxlan source-interface Loopback0
   vxlan udp-port 4789
   vxlan vlan 50 vni 10050
   vxlan vlan 60 vni 10060
   vxlan vlan 90 vni 10090
   vxlan vrf VRF-SERVICES vni 50003
!
ip virtual-router mac-address 00:00:00:11:11:11
!
router bgp 65003
   router-id 10.1.0.13
   bgp log-neighbor-changes
   maximum-paths 2
   neighbor 10.0.0.4  remote-as 65000
   neighbor 10.0.0.4  description spine-01
   neighbor 10.0.0.4  bfd
   neighbor 10.0.0.4  timers 3 9
   neighbor 10.0.0.4  send-community extended
   neighbor 10.0.0.4  maximum-routes 12000
   neighbor 10.0.0.20 remote-as 65000
   neighbor 10.0.0.20 description spine-02
   neighbor 10.0.0.20 bfd
   neighbor 10.0.0.20 timers 3 9
   neighbor 10.0.0.20 send-community extended
   neighbor 10.0.0.20 maximum-routes 12000
   neighbor EVPN-OVERLAY peer group
   neighbor EVPN-OVERLAY update-source Loopback0
   neighbor EVPN-OVERLAY ebgp-multihop 3
   neighbor EVPN-OVERLAY send-community extended
   neighbor EVPN-OVERLAY maximum-routes 0
   neighbor 10.1.0.1 peer group EVPN-OVERLAY
   neighbor 10.1.0.1 remote-as 65000
   neighbor 10.1.0.1 description spine-01-evpn
   neighbor 10.1.0.2 peer group EVPN-OVERLAY
   neighbor 10.1.0.2 remote-as 65000
   neighbor 10.1.0.2 description spine-02-evpn
   address-family ipv4
      neighbor 10.0.0.4  activate
      neighbor 10.0.0.20 activate
      network 10.1.0.13/32
   address-family evpn
      neighbor EVPN-OVERLAY activate
   vrf VRF-SERVICES
      rd 10.1.0.13:50003
      route-target import evpn 65000:50001
      route-target import evpn 65000:50002
      route-target import evpn 65000:50003
      route-target import evpn 65000:50004
      route-target export evpn 65000:50003
      redistribute connected
!
end
