! leaf-04 -- ASN 65004 | AI/GPU Zone
hostname leaf-04
!
service routing protocols model multi-agent
!
no aaa root
username admin privilege 15 role network-admin secret admin
!
management api http-commands
   protocol https
   no shutdown
!
vrf instance VRF-AI
!
ip routing
ip routing vrf VRF-AI
!
interface Loopback0
   description VTEP/Router-ID
   ip address 10.1.0.14/32
!
interface Ethernet1
   description P2P to spine-01
   no switchport
   ip address 10.0.0.7/31
   bfd interval 300 min-rx 300 multiplier 3
   no shutdown
!
interface Ethernet2
   description P2P to spine-02
   no switchport
   ip address 10.0.0.23/31
   bfd interval 300 min-rx 300 multiplier 3
   no shutdown
!
interface Ethernet3
   description server-ai-01
   switchport mode access
   switchport access vlan 80
   no shutdown
!
interface Ethernet4
   description server-ai-02
   switchport mode access
   switchport access vlan 80
   no shutdown
!
vlan 80
   name AI-GPU-CLUSTER
!
vlan 90
   name OOB-MGMT-OVERLAY
!
interface Vlan80
   description AI-GPU-CLUSTER gateway
   vrf VRF-AI
   ip address virtual 192.168.80.1/24
   no shutdown
!
interface Vxlan1
   vxlan source-interface Loopback0
   vxlan udp-port 4789
   vxlan vlan 80 vni 10080
   vxlan vlan 90 vni 10090
   vxlan vrf VRF-AI vni 50004
!
ip virtual-router mac-address 00:00:00:11:11:11
!
router bgp 65004
   router-id 10.1.0.14
   bgp log-neighbor-changes
   maximum-paths 2
   neighbor 10.0.0.6  remote-as 65000
   neighbor 10.0.0.6  description spine-01
   neighbor 10.0.0.6  bfd
   neighbor 10.0.0.6  timers 3 9
   neighbor 10.0.0.6  send-community extended
   neighbor 10.0.0.6  maximum-routes 12000
   neighbor 10.0.0.22 remote-as 65000
   neighbor 10.0.0.22 description spine-02
   neighbor 10.0.0.22 bfd
   neighbor 10.0.0.22 timers 3 9
   neighbor 10.0.0.22 send-community extended
   neighbor 10.0.0.22 maximum-routes 12000
   neighbor EVPN-OVERLAY peer group
   neighbor EVPN-OVERLAY update-source Loopback0
   neighbor EVPN-OVERLAY ebgp-multihop 3
   neighbor EVPN-OVERLAY send-community extended
   neighbor EVPN-OVERLAY maximum-routes 0
   neighbor 10.1.0.1 peer group EVPN-OVERLAY
   neighbor 10.1.0.1 remote-as 65000
   neighbor 10.1.0.1 description spine-01-evpn
   neighbor 10.1.0.2 peer group EVPN-OVERLAY
   neighbor 10.1.0.2 remote-as 65000
   neighbor 10.1.0.2 description spine-02-evpn
   address-family ipv4
      neighbor 10.0.0.6  activate
      neighbor 10.0.0.22 activate
      network 10.1.0.14/32
   address-family evpn
      neighbor EVPN-OVERLAY activate
   vrf VRF-AI
      rd 10.1.0.14:50004
      route-target import evpn 65000:50001
      route-target import evpn 65000:50002
      route-target import evpn 65000:50003
      route-target import evpn 65000:50004
      route-target export evpn 65000:50004
      redistribute connected
!
end
