! leaf-02 -- ASN 65002 | Research Zone
hostname leaf-02
!
service routing protocols model multi-agent
!
no aaa root
username admin privilege 15 role network-admin secret admin
!
management api http-commands
   protocol https
   no shutdown
!
vrf instance VRF-RESEARCH
!
ip routing
ip routing vrf VRF-RESEARCH
!
interface Loopback0
   description VTEP/Router-ID
   ip address 10.1.0.12/32
!
interface Ethernet1
   description P2P to spine-01
   no switchport
   ip address 10.0.0.3/31
   bfd interval 300 min-rx 300 multiplier 3
   no shutdown
!
interface Ethernet2
   description P2P to spine-02
   no switchport
   ip address 10.0.0.19/31
   bfd interval 300 min-rx 300 multiplier 3
   no shutdown
!
interface Ethernet3
   description server-res-01
   switchport mode access
   switchport access vlan 30
   no shutdown
!
interface Ethernet4
   description server-res-02
   switchport mode access
   switchport access vlan 40
   no shutdown
!
vlan 30
   name RESEARCH-COMPUTE
!
vlan 40
   name RESEARCH-SIMUL
!
vlan 90
   name OOB-MGMT-OVERLAY
!
interface Vlan30
   description RESEARCH-COMPUTE gateway
   vrf VRF-RESEARCH
   ip address virtual 192.168.30.1/24
   no shutdown
!
interface Vlan40
   description RESEARCH-SIMUL gateway
   vrf VRF-RESEARCH
   ip address virtual 192.168.40.1/24
   no shutdown
!
interface Vxlan1
   vxlan source-interface Loopback0
   vxlan udp-port 4789
   vxlan vlan 30 vni 10030
   vxlan vlan 40 vni 10040
   vxlan vlan 90 vni 10090
   vxlan vrf VRF-RESEARCH vni 50002
!
ip virtual-router mac-address 00:00:00:11:11:11
!
router bgp 65002
   router-id 10.1.0.12
   bgp log-neighbor-changes
   maximum-paths 2
   neighbor 10.0.0.2  remote-as 65000
   neighbor 10.0.0.2  description spine-01
   neighbor 10.0.0.2  bfd
   neighbor 10.0.0.2  timers 3 9
   neighbor 10.0.0.2  send-community extended
   neighbor 10.0.0.2  maximum-routes 12000
   neighbor 10.0.0.18 remote-as 65000
   neighbor 10.0.0.18 description spine-02
   neighbor 10.0.0.18 bfd
   neighbor 10.0.0.18 timers 3 9
   neighbor 10.0.0.18 send-community extended
   neighbor 10.0.0.18 maximum-routes 12000
   neighbor EVPN-OVERLAY peer group
   neighbor EVPN-OVERLAY update-source Loopback0
   neighbor EVPN-OVERLAY ebgp-multihop 3
   neighbor EVPN-OVERLAY send-community extended
   neighbor EVPN-OVERLAY maximum-routes 0
   neighbor 10.1.0.1 peer group EVPN-OVERLAY
   neighbor 10.1.0.1 remote-as 65000
   neighbor 10.1.0.1 description spine-01-evpn
   neighbor 10.1.0.2 peer group EVPN-OVERLAY
   neighbor 10.1.0.2 remote-as 65000
   neighbor 10.1.0.2 description spine-02-evpn
   address-family ipv4
      neighbor 10.0.0.2  activate
      neighbor 10.0.0.18 activate
      network 10.1.0.12/32
   address-family evpn
      neighbor EVPN-OVERLAY activate
   vrf VRF-RESEARCH
      rd 10.1.0.12:50002
      route-target import evpn 65000:50001
      route-target import evpn 65000:50002
      route-target import evpn 65000:50003
      route-target import evpn 65000:50004
      route-target export evpn 65000:50002
      redistribute connected
!
end
